   "source": [
    "# ── 4B. LightGBM Classifier (Alternative) ────────────────────────────────────\n",
    "\n",
    "lgb_model = lgb.LGBMClassifier(\n",
    "    objective      = 'multiclass',\n",
    "    num_class      = 3,\n",
    "    n_estimators   = 300,\n",
