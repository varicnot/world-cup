   "source": [
    "# ── 4C. Feature Importance Plot ───────────────────────────────────────────────\n",
    "\n",
    "importances = xgb_model.feature_importances_\n",
    "feat_df = pd.DataFrame({'feature': FEATURES, 'importance': importances})\n",
