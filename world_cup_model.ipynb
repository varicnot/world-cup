   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": ["## 5. Knockout Match Post-Processing (Draw Masking)"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def predict_match(team_a, team_b, is_knockout, model=xgb_model):\n",
    "    \"\"\"\n",
    "    Predict outcome probabilities for a match.\n",
    "    For knockout matches, draw probability is redistributed to Win/Loss.\n",
    "    Returns: dict with P_win, P_draw, P_loss\n",
    "    \"\"\"\n",
    "    # Build feature vector (use current Elo; socioeconomic & rolling from last known)\n",
    "    ea = get_elo(team_a)\n",
    "    eb = get_elo(team_b)\n",
    "    elo_diff = ea - eb\n",
    "\n",
    "    # Retrieve last known rolling features for each team (from team_history)\n",
    "    def last_roll(team):\n",
    "        hist = team_history.get(team, [])\n",
    "        if not hist:\n",
    "            return 0.0, 0.35\n",
    "        return hist[-1]['xg_for'], hist[-1]['sot_rate']\n",
    "\n",
    "    xg_a, sot_a = last_roll(team_a)\n",
    "    xg_b, sot_b = last_roll(team_b)\n",
    "\n",
    "    # Socioeconomic: pull current year from WB\n",
    "    current_year = datetime.now().year\n",
    "    log_gdp_diff, log_pop_diff = get_socioeconomic_diff(team_a, team_b, current_year)\n",
    "    log_gdp_diff = log_gdp_diff if not np.isnan(log_gdp_diff) else 0.0\n",
    "    log_pop_diff = log_pop_diff if not np.isnan(log_pop_diff) else 0.0\n",
    "\n",
    "    feat_vec = np.array([[\n",
    "        elo_diff,\n",
    "        xg_a - xg_b,\n",
    "        sot_a - sot_b,\n",
    "        log_gdp_diff,\n",
    "        log_pop_diff,\n",
    "        0.0,           # rest_diff unknown at prediction time; set 0\n",
    "        int(is_knockout)\n",
    "    ]])\n",
    "\n",
    "    probs = model.predict_proba(feat_vec)[0]  # [P_win, P_draw, P_loss]\n",
    "    p_win, p_draw, p_loss = probs\n",
    "\n",
    "    if is_knockout:\n",
    "        # Redistribute draw probability → Win and Loss proportionally\n",
    "        p_win_adj  = p_win  / (p_win + p_loss)\n",
    "        p_loss_adj = p_loss / (p_win + p_loss)\n",
    "        return {'team_a': team_a, 'team_b': team_b,\n",
    "                'P_win': round(p_win_adj, 4), 'P_draw': 0.0,\n",
    "                'P_loss': round(p_loss_adj, 4)}\n",
    "    else:\n",
    "        return {'team_a': team_a, 'team_b': team_b,\n",
    "                'P_win': round(p_win, 4), 'P_draw': round(p_draw, 4),\n",
    "                'P_loss': round(p_loss, 4)}\n",
    "\n",
    "\n",
    "# Example usage\n",
    "result = predict_match('Brazil', 'Germany', is_knockout=True)\n",
    "print(\"Example Prediction (Knockout):\")\n",
    "print(result)\n",
    "\n",
    "result_group = predict_match('France', 'Argentina', is_knockout=False)\n",
    "print(\"\\nExample Prediction (Group Stage):\")\n",
    "print(result_group)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": ["## 6. Goal Prediction — Poisson Regression & Over/Under Classifier"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── 6A. Approach A: Dual Poisson XGBoost Regressors ──────────────────────────\n",
    "\n",
    "from xgboost import XGBRegressor\n",
    "\n",
    "y_goals_a = df_model['goals_a'].values\n",
    "y_goals_b = df_model['goals_b'].values\n",
    "\n",
    "poisson_a = XGBRegressor(\n",
    "    objective='count:poisson',\n",
    "    n_estimators=300, max_depth=4,\n",
    "    learning_rate=0.05, subsample=0.8,\n",
    "    random_state=42\n",
    ")\n",
    "poisson_b = XGBRegressor(\n",
    "    objective='count:poisson',\n",
    "    n_estimators=300, max_depth=4,\n",
    "    learning_rate=0.05, subsample=0.8,\n",
    "    random_state=42\n",
    ")\n",
    "\n",
    "poisson_a.fit(X_train, y_goals_a[train_mask])\n",
    "poisson_b.fit(X_train, y_goals_b[train_mask])\n",
    "\n",
    "lambda_a_preds = poisson_a.predict(X_test).clip(min=0)\n",
    "lambda_b_preds = poisson_b.predict(X_test).clip(min=0)\n",
    "\n",
    "print(\"Poisson Regressors trained.\")\n",
    "print(f\"Mean predicted λ_A: {lambda_a_preds.mean():.2f}  |  Mean λ_B: {lambda_b_preds.mean():.2f}\")\n",
    "print(f\"Actual mean goals A: {y_goals_a[test_mask].mean():.2f} | Actual B: {y_goals_b[test_mask].mean():.2f}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── 6B. Scoreline Probability Matrix from Poisson ─────────────────────────────\n",
    "\n",
    "def scoreline_matrix(lambda_a, lambda_b, max_goals=6):\n",
    "    \"\"\"\n",
    "    Returns a DataFrame of P(goals_A=i, goals_B=j)\n",
    "    using independent Poisson distributions.\n",
    "    \"\"\"\n",
    "    matrix = np.zeros((max_goals + 1, max_goals + 1))\n",
    "    for i in range(max_goals + 1):\n",
    "        for j in range(max_goals + 1):\n",
    "            matrix[i, j] = poisson.pmf(i, lambda_a) * poisson.pmf(j, lambda_b)\n",
    "    return pd.DataFrame(\n",
    "        matrix,\n",
    "        index=[f'A={i}' for i in range(max_goals + 1)],\n",
    "        columns=[f'B={j}' for j in range(max_goals + 1)]\n",
    "    )\n",
    "\n",
    "# Example\n",
    "lam_a, lam_b = 1.6, 1.1  # Example: Brazil vs Germany\n",
    "score_mat = scoreline_matrix(lam_a, lam_b)\n",
    "\n",
    "plt.figure(figsize=(8, 6))\n",
    "sns.heatmap(score_mat, annot=True, fmt='.3f', cmap='YlOrRd')\n",
    "plt.title(f'Scoreline Probability Matrix (λ_A={lam_a}, λ_B={lam_b})')\n",
    "plt.xlabel('Team B Goals')\n",
    "plt.ylabel('Team A Goals')\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "# Aggregate win/draw/loss from matrix\n",
    "mat = score_mat.values\n",
    "p_win_poisson  = np.tril(mat, k=-1).sum()\n",
    "p_draw_poisson = np.trace(mat)\n",
    "p_loss_poisson = np.triu(mat, k=1).sum()\n",
    "print(f\"\\nPoisson-derived: P(A Win)={p_win_poisson:.3f} | P(Draw)={p_draw_poisson:.3f} | P(B Win)={p_loss_poisson:.3f}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── 6C. Approach B: Over/Under 2.5 Binary Classifier ─────────────────────────\n",
    "\n",
    "THRESHOLD = 2.5\n",
    "y_ou = (df_model['goals_a'] + df_model['goals_b'] > THRESHOLD).astype(int).values\n",
    "\n",
    "ou_model = xgb.XGBClassifier(\n",
    "    objective   = 'binary:logistic',\n",
    "    n_estimators= 300,\n",
    "    max_depth   = 4,\n",
    "    learning_rate=0.05,\n",
    "    subsample   = 0.8,\n",
    "    colsample_bytree = 0.8,\n",
    "    eval_metric = 'logloss',\n",
    "    random_state= 42,\n",
    ")\n",
    "\n",
    "ou_model.fit(\n",
    "    X_train, y_ou[train_mask],\n",
    "    eval_set=[(X_test, y_ou[test_mask])],\n",
    "    verbose=False\n",
    ")\n",
    "\n",
    "ou_preds = ou_model.predict(X_test)\n",
    "ou_probs = ou_model.predict_proba(X_test)[:, 1]\n",
    "\n",
    "print(f\"Over/Under 2.5 Accuracy : {accuracy_score(y_ou[test_mask], ou_preds):.4f}\")\n",
    "print(f\"Over/Under 2.5 Log-Loss : {log_loss(y_ou[test_mask], ou_probs):.4f}\")\n",
    "print(\"\\nClassification Report:\")\n",
    "print(classification_report(y_ou[test_mask], ou_preds, target_names=['Under 2.5', 'Over 2.5']))"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": ["## 7. Full Prediction Wrapper"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def full_match_prediction(team_a, team_b, is_knockout=False,\n",
    "                           ou_threshold=2.5,\n",
    "                           outcome_model=xgb_model,\n",
    "                           goals_model_a=poisson_a,\n",
    "                           goals_model_b=poisson_b,\n",
    "                           ou_clf=ou_model):\n",
    "    \"\"\"\n",
    "    Unified prediction function.\n",
    "    Returns:\n",
    "      - Outcome probabilities (Win/Draw/Loss)\n",
    "      - Expected goals (λ_A, λ_B)\n",
    "      - Most likely scoreline\n",
    "      - Over/Under prediction\n",
    "    \"\"\"\n",
    "    # Build feature vector\n",
    "    ea = get_elo(team_a)\n",
    "    eb = get_elo(team_b)\n",
    "    elo_diff = ea - eb\n",
    "\n",
    "    def last_roll(team):\n",
    "        hist = team_history.get(team, [])\n",
    "        if not hist:\n",
    "            return 0.0, 0.35\n",
    "        return hist[-1]['xg_for'], hist[-1]['sot_rate']\n",
    "\n",
    "    xg_a, sot_a = last_roll(team_a)\n",
    "    xg_b, sot_b = last_roll(team_b)\n",
    "\n",
    "    current_year = datetime.now().year\n",
    "    log_gdp_diff, log_pop_diff = get_socioeconomic_diff(team_a, team_b, current_year)\n",
    "    log_gdp_diff = log_gdp_diff if not np.isnan(log_gdp_diff) else 0.0\n",
    "    log_pop_diff = log_pop_diff if not np.isnan(log_pop_diff) else 0.0\n",
    "\n",
    "    fv = np.array([[\n",
    "        elo_diff,\n",
    "        xg_a - xg_b,\n",
    "        sot_a - sot_b,\n",
    "        log_gdp_diff,\n",
    "        log_pop_diff,\n",
    "        0.0,\n",
    "        int(is_knockout)\n",
    "    ]])\n",
    "\n",
    "    # Outcome probabilities\n",
    "    probs = outcome_model.predict_proba(fv)[0]\n",
    "    p_win, p_draw, p_loss = probs\n",
    "    if is_knockout:\n",
    "        p_win_adj  = round(p_win  / (p_win + p_loss), 4)\n",
    "        p_loss_adj = round(p_loss / (p_win + p_loss), 4)\n",
    "        outcome_probs = {'P_win': p_win_adj, 'P_draw': 0.0, 'P_loss': p_loss_adj}\n",
    "    else:\n",
    "        outcome_probs = {'P_win': round(p_win, 4), 'P_draw': round(p_draw, 4), 'P_loss': round(p_loss, 4)}\n",
    "\n",
    "    # Expected goals\n",
    "    lam_a = float(goals_model_a.predict(fv).clip(min=0)[0])\n",
    "    lam_b = float(goals_model_b.predict(fv).clip(min=0)[0])\n",
    "\n",
    "    # Most likely scoreline\n",
    "    mat = scoreline_matrix(lam_a, lam_b)\n",
    "    flat_max = mat.values.argmax()\n",
    "    best_i, best_j = divmod(flat_max, mat.shape[1])\n",
    "\n",
    "    # Over/Under\n",
    "    ou_prob = float(ou_clf.predict_proba(fv)[0, 1])\n",
    "    ou_label = f'Over {ou_threshold}' if ou_prob > 0.5 else f'Under {ou_threshold}'\n",
    "\n",
    "    print(\"=\" * 45)\n",
    "    print(f\"  {team_a}  vs  {team_b}\")\n",
    "    print(f\"  {'KNOCKOUT' if is_knockout else 'GROUP STAGE'}\")\n",
    "    print(\"=\" * 45)\n",
    "    print(f\"  Outcome  : Win={outcome_probs['P_win']:.1%} | Draw={outcome_probs['P_draw']:.1%} | Loss={outcome_probs['P_loss']:.1%}\")\n",
    "    print(f\"  Exp Goals: {team_a} λ={lam_a:.2f} | {team_b} λ={lam_b:.2f}\")\n",
    "    print(f\"  Top Score: {team_a} {best_i}-{best_j} {team_b} (P={mat.values[best_i, best_j]:.3f})\")\n",
    "    print(f\"  Over/Under {ou_threshold}: {ou_label} (P_over={ou_prob:.1%})\")\n",
    "    print(\"=\" * 45)\n",
    "\n",
    "    return {\n",
    "        'outcome': outcome_probs,\n",
    "        'lambda_a': lam_a, 'lambda_b': lam_b,\n",
    "        'best_scoreline': f\"{best_i}-{best_j}\",\n",
    "        'ou_prediction': ou_label, 'ou_prob_over': ou_prob\n",
    "    }\n",
    "\n",
    "\n",
    "# Run a sample prediction\n",
    "full_match_prediction('Brazil', 'Germany', is_knockout=True)"
   ]
  },
