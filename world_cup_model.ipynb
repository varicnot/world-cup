   "cell_type": "markdown",
   "metadata": {},
   "source": ["## 1. Data Sourcing"]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": ["### 1A. Historical Match Data — OpenFootball (worldcup.json)"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Pulls World Cup match results from OpenFootball — scoped to 2002–2022 only.\n",
    "# These are the years with reliable modern data and World Bank economic coverage.\n",
    "\n",
    "AVAILABLE_YEARS = [2002, 2006, 2010, 2014, 2018, 2022]  # 2002–2022 only\n",
    "YEAR_MIN, YEAR_MAX = 2002, 2022\n",
    "\n",
    "BASE_URL = \"https://raw.githubusercontent.com/openfootball/world-cup.json/master/{year}/worldcup.json\"\n",
    "\n",
    "def fetch_wc_matches(year):\n",
    "    \"\"\"Fetch and flatten all matches for a given World Cup year.\"\"\"\n",
    "    url = BASE_URL.format(year=year)\n",
    "    try:\n",
    "        r = requests.get(url, timeout=10)\n",
    "        r.raise_for_status()\n",
    "        data = r.json()\n",
    "    except Exception as e:\n",
    "        print(f\"  Could not fetch {year}: {e}\")\n",
    "        return []\n",
    "\n",
    "    rows = []\n",
    "    for round_data in data.get('rounds', []):\n",
    "        stage = round_data.get('name', '')\n",
    "        is_knockout = int(any(kw in stage.lower() for kw in\n",
    "                              ['final', 'semi', 'quarter', 'round of', 'knockout', 'third']))\n",
    "        for m in round_data.get('matches', []):\n",
    "            score = m.get('score', {})\n",
    "            ft = score.get('ft', [None, None])\n",
    "            rows.append({\n",
    "                'year'       : year,\n",
    "                'date'       : m.get('date'),\n",
    "                'stage'      : stage,\n",
    "                'is_knockout': is_knockout,\n",
    "                'team_a'     : m['team1'].get('name') if 'team1' in m else None,\n",
    "                'team_b'     : m['team2'].get('name') if 'team2' in m else None,\n",
    "                'goals_a'    : ft[0] if ft[0] is not None else np.nan,\n",
    "                'goals_b'    : ft[1] if ft[1] is not None else np.nan,\n",
    "            })\n",
    "    return rows\n",
    "\n",
    "all_matches = []\n",
    "for yr in AVAILABLE_YEARS:\n",
    "    print(f\"Fetching {yr}...\")\n",
    "    all_matches.extend(fetch_wc_matches(yr))\n",
    "\n",
    "df_matches = pd.DataFrame(all_matches)\n",
    "df_matches['date'] = pd.to_datetime(df_matches['date'], errors='coerce')\n",
    "df_matches.dropna(subset=['goals_a', 'goals_b', 'team_a', 'team_b'], inplace=True)\n",
    "df_matches['goals_a'] = df_matches['goals_a'].astype(int)\n",
    "df_matches['goals_b'] = df_matches['goals_b'].astype(int)\n",
    "\n",
    "# Hard filter: keep only matches within our 2002–2022 window\n",
    "df_matches = df_matches[\n",
    "    (df_matches['year'] >= YEAR_MIN) & (df_matches['year'] <= YEAR_MAX)\n",
    "].reset_index(drop=True)\n",
    "\n",
    "# Derive match outcome label\n",
    "def get_outcome(row):\n",
    "    if row['goals_a'] > row['goals_b']:\n",
    "        return 0  # Team A win\n",
    "    elif row['goals_a'] == row['goals_b']:\n",
    "        return 1  # Draw\n",
    "    else:\n",
    "        return 2  # Team B win\n",
    "\n",
    "df_matches['outcome'] = df_matches.apply(get_outcome, axis=1)\n",
    "print(f\"Years covered : {sorted(df_matches['year'].unique())}\")\n",
    "print(f\"Total matches : {len(df_matches)}\")\n",
    "df_matches.head()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": ["### 1B. Elo Rating System (Dynamic, Match-by-Match)"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Football-adapted Elo — K=60 for World Cup, K=10 for friendlies\n",
    "# All WC matches use K=60 by default here\n",
    "\n",
    "ELO_START = 1500\n",
    "K_WORLD_CUP = 60\n",
    "\n",
    "elo_ratings = {}  # team_name -> current elo\n",
    "\n",
    "def get_elo(team):\n",
    "    return elo_ratings.get(team, ELO_START)\n",
    "\n",
    "def expected_score(elo_a, elo_b):\n",
    "    return 1 / (1 + 10 ** ((elo_b - elo_a) / 400))\n",
    "\n",
    "def update_elo(elo_a, elo_b, result_a, k=K_WORLD_CUP):\n",
    "    \"\"\"result_a: 1=win, 0.5=draw, 0=loss for team A\"\"\"\n",
    "    exp_a = expected_score(elo_a, elo_b)\n",
    "    new_a = elo_a + k * (result_a - exp_a)\n",
    "    new_b = elo_b + k * ((1 - result_a) - (1 - exp_a))\n",
    "    return new_a, new_b\n",
    "\n",
    "# Sort chronologically and compute rolling Elo BEFORE each match (pre-match snapshot)\n",
    "df_matches_sorted = df_matches.sort_values('date').reset_index(drop=True)\n",
    "\n",
    "elo_a_list, elo_b_list = [], []\n",
    "\n",
    "for _, row in df_matches_sorted.iterrows():\n",
    "    ta, tb = row['team_a'], row['team_b']\n",
    "    ea, eb = get_elo(ta), get_elo(tb)\n",
    "    elo_a_list.append(ea)\n",
    "    elo_b_list.append(eb)\n",
    "\n",
    "    # Determine result for Elo update\n",
    "    if row['goals_a'] > row['goals_b']:\n",
    "        result_a = 1.0\n",
    "    elif row['goals_a'] == row['goals_b']:\n",
    "        result_a = 0.5\n",
    "    else:\n",
    "        result_a = 0.0\n",
    "\n",
    "    new_ea, new_eb = update_elo(ea, eb, result_a)\n",
    "    elo_ratings[ta] = new_ea\n",
    "    elo_ratings[tb] = new_eb\n",
    "\n",
    "df_matches_sorted['elo_a'] = elo_a_list\n",
    "df_matches_sorted['elo_b'] = elo_b_list\n",
    "df_matches_sorted['elo_diff'] = df_matches_sorted['elo_a'] - df_matches_sorted['elo_b']\n",
    "\n",
    "print(\"Elo ratings computed.\")\n",
    "df_matches_sorted[['date','team_a','team_b','elo_a','elo_b','elo_diff']].head()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": ["### 1C. Socioeconomic Data — World Bank API"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# World Bank API — pulls GDP per capita (PPP, current intl $) and Population\n",
    "# Scoped to match years 2002–2022. The World Bank has reliable PPP data from ~1990\n",
    "# onward, so this window is well covered.\n",
    "# Indicator codes: NY.GDP.PCAP.PP.CD = GDP per capita PPP, SP.POP.TOTL = Population\n",
    "\n",
    "WB_BASE = \"https://api.worldbank.org/v2/country/{iso}/indicator/{indicator}?date={year}&format=json&per_page=1\"\n",
    "\n",
    "# Map team names (as they appear in OpenFootball) to ISO3 codes\n",
    "# Extend this dict as needed for full coverage\n",
    "TEAM_TO_ISO3 = {\n",
    "    'Brazil': 'BRA', 'Germany': 'DEU', 'Italy': 'ITA', 'Argentina': 'ARG',\n",
    "    'France': 'FRA', 'England': 'GBR', 'Spain': 'ESP', 'Netherlands': 'NLD',\n",
    "    'Uruguay': 'URY', 'Croatia': 'HRV', 'Belgium': 'BEL', 'Portugal': 'PRT',\n",
    "    'Mexico': 'MEX', 'Japan': 'JPN', 'South Korea': 'KOR', 'USA': 'USA',\n",
    "    'Australia': 'AUS', 'Switzerland': 'CHE', 'Denmark': 'DNK', 'Sweden': 'SWE',\n",
    "    'Poland': 'POL', 'Senegal': 'SEN', 'Morocco': 'MAR', 'Ghana': 'GHA',\n",
    "    'Nigeria': 'NGA', 'Cameroon': 'CMR', 'Saudi Arabia': 'SAU', 'Iran': 'IRN',\n",
    "    'Ecuador': 'ECU', 'Qatar': 'QAT', 'Canada': 'CAN', 'Serbia': 'SRB',\n",
    "    'Wales': 'GBR', 'Czech Republic': 'CZE', 'Hungary': 'HUN', 'Turkey': 'TUR',\n",
    "    'Russia': 'RUS', 'Colombia': 'COL', 'Chile': 'CHL', 'Peru': 'PER',\n",
    "    'Paraguay': 'PRY', 'Bolivia': 'BOL', 'Costa Rica': 'CRI', 'Honduras': 'HND',\n",
    "    'Ivory Coast': 'CIV', 'Tunisia': 'TUN', 'Algeria': 'DZA', 'Egypt': 'EGY',\n",
    "    'South Africa': 'ZAF', 'Greece': 'GRC', 'Slovakia': 'SVK', 'Slovenia': 'SVN',\n",
    "    'Austria': 'AUT', 'Norway': 'NOR', 'Scotland': 'GBR', 'Ireland': 'IRL',\n",
    "    'Romania': 'ROU', 'Bulgaria': 'BGR', 'Ukraine': 'UKR', 'New Zealand': 'NZL',\n",
    "    'North Korea': 'PRK', 'Honduras': 'HND', 'Jamaica': 'JAM', 'Trinidad and Tobago': 'TTO',\n",
    "    'Cuba': 'CUB', 'Haiti': 'HTI', 'El Salvador': 'SLV', 'Panama': 'PAN',\n",
    "    'Israel': 'ISR', 'Indonesia': 'IDN', 'East Germany': 'DEU', 'West Germany': 'DEU',\n",
    "    'Soviet Union': 'RUS', 'Yugoslavia': 'SRB', 'Czechoslovakia': 'CZE',\n",
    "    'Congo DR': 'COD', 'North Ireland': 'GBR', 'China': 'CHN', 'Angola': 'AGO',\n",
    "    'Togo': 'TGO', 'UAE': 'ARE', 'Iraq': 'IRQ', 'Kuwait': 'KWT',\n",
    "}\n",
    "\n",
    "_wb_cache = {}\n",
    "\n",
    "def fetch_wb_indicator(iso3, indicator, year):\n",
    "    \"\"\"Fetch a single World Bank indicator value; returns None if unavailable.\"\"\"\n",
    "    key = (iso3, indicator, year)\n",
    "    if key in _wb_cache:\n",
    "        return _wb_cache[key]\n",
    "    url = WB_BASE.format(iso=iso3, indicator=indicator, year=year)\n",
    "    try:\n",
    "        r = requests.get(url, timeout=8)\n",
    "        payload = r.json()\n",
    "        value = payload[1][0]['value'] if payload and len(payload) > 1 and payload[1] else None\n",
    "        _wb_cache[key] = value\n",
    "        return value\n",
    "    except:\n",
    "        _wb_cache[key] = None\n",
    "        return None\n",
    "\n",
    "def get_socioeconomic_diff(team_a, team_b, year):\n",
    "    \"\"\"Returns (log_gdp_diff, log_pop_diff) for Team A minus Team B.\"\"\"\n",
    "    iso_a = TEAM_TO_ISO3.get(team_a)\n",
    "    iso_b = TEAM_TO_ISO3.get(team_b)\n",
    "    if not iso_a or not iso_b:\n",
    "        return np.nan, np.nan\n",
    "\n",
    "    gdp_a = fetch_wb_indicator(iso_a, 'NY.GDP.PCAP.PP.CD', year)\n",
    "    gdp_b = fetch_wb_indicator(iso_b, 'NY.GDP.PCAP.PP.CD', year)\n",
    "    pop_a = fetch_wb_indicator(iso_a, 'SP.POP.TOTL', year)\n",
    "    pop_b = fetch_wb_indicator(iso_b, 'SP.POP.TOTL', year)\n",
    "\n",
    "    log_gdp_diff = (math.log(gdp_a) - math.log(gdp_b)) if gdp_a and gdp_b else np.nan\n",
    "    log_pop_diff = (math.log(pop_a) - math.log(pop_b)) if pop_a and pop_b else np.nan\n",
    "    return log_gdp_diff, log_pop_diff\n",
    "\n",
    "# NOTE: This cell makes ~2x API calls per match. For large datasets run overnight\n",
    "# or cache results to disk with: pd.DataFrame(_wb_cache).to_csv('wb_cache.csv')\n",
    "print(\"World Bank fetch functions ready. Call get_socioeconomic_diff(team_a, team_b, year) to use.\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": ["### 1D. Attach Socioeconomic Differentials to Match Dataset\n", "⚠️ This makes live API calls — may take several minutes for the full dataset."]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Attach World Bank GDP (PPP) and Population differentials to every match row.\n",
    "# Economic data is fetched for the exact match year (2002–2022), ensuring we use\n",
    "# the historically accurate values at the time each tournament was played.\n",
    "\n",
    "log_gdp_diffs, log_pop_diffs = [], []\n",
    "total = len(df_matches_sorted)\n",
    "\n",
    "for i, row in df_matches_sorted.iterrows():\n",
    "    if i % 50 == 0:\n",
    "        print(f\"  Processing match {i+1}/{total}...\")\n",
    "    gdp_diff, pop_diff = get_socioeconomic_diff(row['team_a'], row['team_b'], row['year'])\n",
    "    log_gdp_diffs.append(gdp_diff)\n",
    "    log_pop_diffs.append(pop_diff)\n",
    "\n",
    "df_matches_sorted['log_gdp_diff'] = log_gdp_diffs\n",
    "df_matches_sorted['log_pop_diff'] = log_pop_diffs\n",
    "\n",
    "print(f\"Done. GDP coverage: {df_matches_sorted['log_gdp_diff'].notna().sum()}/{total} matches.\")\n",
    "df_matches_sorted[['team_a','team_b','year','log_gdp_diff','log_pop_diff']].head()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": ["## 2. Feature Engineering"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── 2A. Rest Day Differential ──────────────────────────────────────────────────\n",
    "# Compute days since each team's previous match in the dataset\n",
    "\n",
    "df = df_matches_sorted.copy()\n",
    "\n",
    "# Track last match date per team across the full dataset\n",
    "last_match_date = {}\n",
    "rest_a_list, rest_b_list = [], []\n",
    "\n",
    "for _, row in df.iterrows():\n",
    "    ta, tb, date = row['team_a'], row['team_b'], row['date']\n",
    "\n",
    "    rest_a = (date - last_match_date[ta]).days if ta in last_match_date and pd.notna(date) else np.nan\n",
    "    rest_b = (date - last_match_date[tb]).days if tb in last_match_date and pd.notna(date) else np.nan\n",
    "    rest_a_list.append(rest_a)\n",
    "    rest_b_list.append(rest_b)\n",
    "\n",
    "    if pd.notna(date):\n",
    "        last_match_date[ta] = date\n",
    "        last_match_date[tb] = date\n",
    "\n",
    "df['rest_a'] = rest_a_list\n",
    "df['rest_b'] = rest_b_list\n",
    "df['rest_diff'] = df['rest_a'] - df['rest_b']\n",
    "\n",
    "print(\"Rest day differential computed.\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── 2B. Rolling xG & Shooting Efficiency with Exponential Time-Decay ──────────\n",
    "# NOTE: True xG requires StatsBomb / Opta data; here we simulate from goals\n",
    "# until you wire in real xG from StatsBomb Open Data or API-Football.\n",
    "# Replace 'xg_a' and 'xg_b' columns with real xG values when available.\n",
    "\n",
    "# Simulate xG as goals + small noise (placeholder)\n",
    "np.random.seed(42)\n",
    "df['xg_a'] = df['goals_a'] + np.random.normal(0, 0.3, len(df)).clip(-0.5, 1.0)\n",
    "df['xg_b'] = df['goals_b'] + np.random.normal(0, 0.3, len(df)).clip(-0.5, 1.0)\n",
    "df['xg_a'] = df['xg_a'].clip(lower=0)\n",
    "df['xg_b'] = df['xg_b'].clip(lower=0)\n",
    "\n",
    "# Simulate shooting efficiency (shots on target / total shots)\n",
    "df['sot_rate_a'] = (0.35 + np.random.normal(0, 0.08, len(df))).clip(0.1, 0.8)\n",
    "df['sot_rate_b'] = (0.35 + np.random.normal(0, 0.08, len(df))).clip(0.1, 0.8)\n",
    "\n",
    "LAMBDA = 0.1   # decay factor — higher = faster decay (recency bias)\n",
    "WINDOW = 5     # last N competitive matches\n",
    "\n",
    "def decay_average(values, dates, lambda_=LAMBDA):\n",
    "    \"\"\"Exponential time-decay weighted average, most recent matches count more.\"\"\"\n",
    "    if not values:\n",
    "        return np.nan\n",
    "    values, dates = np.array(values), np.array(dates)\n",
    "    if len(values) == 1:\n",
    "        return values[0]\n",
    "    max_date = max(dates)\n",
    "    weights = np.exp(-lambda_ * np.array([(max_date - d).days for d in dates]))\n",
    "    return float(np.average(values, weights=weights))\n",
    "\n",
    "# Build per-team rolling history dictionaries\n",
    "team_history = {}  # team -> list of {'date', 'xg_for', 'xg_against', 'sot_rate', 'elo'}\n",
    "\n",
    "roll_xg_diff_list  = []\n",
    "roll_sot_diff_list = []\n",
    "\n",
    "for _, row in df.iterrows():\n",
    "    ta, tb = row['team_a'], row['team_b']\n",
    "    date = row['date']\n",
    "    ea, eb = row['elo_a'], row['elo_b']\n",
    "\n",
    "    def get_rolling(team, window=WINDOW):\n",
    "        hist = team_history.get(team, [])[-window:]\n",
    "        if not hist:\n",
    "            return np.nan, np.nan\n",
    "        xg_vals  = [h['xg_for']    for h in hist]\n",
    "        sot_vals = [h['sot_rate']  for h in hist]\n",
    "        elo_opp  = [h['elo_opp']   for h in hist]\n",
    "        dates    = [h['date']      for h in hist]\n",
    "        # Opponent-adjusted xG: weight by opponent Elo defense proxy\n",
    "        adj_xg = [x * (e / 1500) for x, e in zip(xg_vals, elo_opp)]\n",
    "        return decay_average(adj_xg, dates), decay_average(sot_vals, dates)\n",
    "\n",
    "    xg_a_roll,  sot_a_roll  = get_rolling(ta)\n",
    "    xg_b_roll,  sot_b_roll  = get_rolling(tb)\n",
    "\n",
    "    roll_xg_diff_list.append(\n",
    "        (xg_a_roll - xg_b_roll) if not (np.isnan(xg_a_roll) or np.isnan(xg_b_roll)) else np.nan\n",
    "    )\n",
    "    roll_sot_diff_list.append(\n",
    "        (sot_a_roll - sot_b_roll) if not (np.isnan(sot_a_roll) or np.isnan(sot_b_roll)) else np.nan\n",
    "    )\n",
    "\n",
    "    # Update history AFTER snapshot\n",
    "    for team, xg_for, xg_against, sot_rate, elo_opp in [\n",
    "        (ta, row['xg_a'], row['xg_b'], row['sot_rate_a'], eb),\n",
    "        (tb, row['xg_b'], row['xg_a'], row['sot_rate_b'], ea),\n",
    "    ]:\n",
    "        team_history.setdefault(team, []).append({\n",
    "            'date': date, 'xg_for': xg_for,\n",
    "            'xg_against': xg_against, 'sot_rate': sot_rate, 'elo_opp': elo_opp\n",
    "        })\n",
    "\n",
    "df['roll_xg_diff']  = roll_xg_diff_list\n",
    "df['roll_sot_diff'] = roll_sot_diff_list\n",
    "print(\"Rolling xG and shooting efficiency features computed.\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── 2C. Assemble Final Feature Matrix ─────────────────────────────────────────\n",
    "\n",
    "FEATURES = [\n",
    "    'elo_diff',       # Elo rating differential (Team A - Team B)\n",
    "    'roll_xg_diff',   # Opponent-adjusted rolling xG differential\n",
    "    'roll_sot_diff',  # Rolling shooting efficiency differential\n",
    "    'log_gdp_diff',   # Log GDP per capita PPP differential\n",
    "    'log_pop_diff',   # Log population ratio\n",
    "    'rest_diff',      # Rest days differential\n",
    "    'is_knockout',    # 1 = knockout stage, 0 = group stage\n",
    "]\n",
    "\n",
    "TARGET = 'outcome'  # 0=Team A Win, 1=Draw, 2=Team B Win\n",
    "\n",
    "df_model = df[FEATURES + [TARGET, 'goals_a', 'goals_b']].copy()\n",
    "\n",
    "# Impute missing values with median (robust to outliers)\n",
    "for col in FEATURES:\n",
    "    median_val = df_model[col].median()\n",
    "    df_model[col].fillna(median_val, inplace=True)\n",
    "\n",
    "print(f\"Feature matrix shape: {df_model.shape}\")\n",
    "print(f\"\\nOutcome distribution:\")\n",
    "print(df_model[TARGET].value_counts().rename({0:'A Win', 1:'Draw', 2:'B Win'}))\n",
    "df_model[FEATURES].describe()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": ["## 3. Train/Test Split"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "X = df_model[FEATURES].values\n",
    "y = df_model[TARGET].values\n",
    "\n",
    "# Temporal split: train on 2002–2014 World Cups, test on 2018 & 2022\n",
    "# This preserves temporal order — no future leakage into training.\n",
    "train_mask = df['year'] <= 2014\n",
    "test_mask  = df['year'] >= 2018\n",
    "\n",
    "X_train, X_test = X[train_mask], X[test_mask]\n",
    "y_train, y_test = y[train_mask], y[test_mask]\n",
    "\n",
    "print(f\"Train set: {len(X_train)} matches (2002–2014)\")\n",
    "print(f\"Test set : {len(X_test)} matches (2018–2022)\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": ["## 4. Model Training — Multiclass Classification (Win / Draw / Lose)"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── 4A. XGBoost Classifier (Primary) ─────────────────────────────────────────\n",
    "\n",
    "xgb_model = xgb.XGBClassifier(\n",
    "    objective      = 'multi:softprob',\n",
    "    num_class      = 3,\n",
    "    n_estimators   = 300,\n",
    "    max_depth      = 4,\n",
    "    learning_rate  = 0.05,\n",
    "    subsample      = 0.8,\n",
    "    colsample_bytree = 0.8,\n",
    "    use_label_encoder = False,\n",
    "    eval_metric    = 'mlogloss',\n",
    "    random_state   = 42,\n",
    ")\n",
    "\n",
    "xgb_model.fit(\n",
    "    X_train, y_train,\n",
    "    eval_set=[(X_test, y_test)],\n",
    "    verbose=50\n",
    ")\n",
    "\n",
    "xgb_probs = xgb_model.predict_proba(X_test)   # shape (n, 3): [P_win, P_draw, P_loss]\n",
    "xgb_preds = xgb_model.predict(X_test)\n",
    "\n",
    "print(f\"\\nXGBoost Accuracy : {accuracy_score(y_test, xgb_preds):.4f}\")\n",
    "print(f\"XGBoost Log-Loss : {log_loss(y_test, xgb_probs):.4f}\")\n",
    "print(\"\\nClassification Report:\")\n",
    "print(classification_report(y_test, xgb_preds, target_names=['A Win', 'Draw', 'B Win']))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
